# ═══════════════════════════════════════════════════════════════
# Gradify - Environment Variables Setup
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# REQUIRED: Firebase Configuration
# ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ──────────────────────────────────────────────────────────────
# REQUIRED: Gemini API Key
# Purpose: Final scoring, mark allocation, accuracy verification
# Get Key: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────────────────────
# OPTIONAL: NVIDIA API Key (Kimi K2.5)
# Purpose: Enhanced feedback, explanations, cost-effective processing
# Get Key: https://build.nvidia.com/account
# Note: If not provided, system falls back to Gemini-only mode
# ──────────────────────────────────────────────────────────────
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here

# ═══════════════════════════════════════════════════════════════
# How to set up:
# ═══════════════════════════════════════════════════════════════
# 
# 1. Copy this file to `.env.local` in the frontend directory
# 2. Replace all "your_*_here" values with actual API keys
# 3. Keep this file safe - never commit to version control
# 4. For production, use environment manager (GitHub Secrets, etc.)
#
# ═══════════════════════════════════════════════════════════════
